{
  "rules": {
    ".read": false,
    ".write": false,
    "sync": {
      "$hash": {
        ".read": true,
        ".write": true
      }
    },
    "presence": {
      ".read": true,
      "$page": {
        "$uid": {
          ".write": true
        }
      }
    },
    "stats": {
      ".read": true,
      "$page": {
        ".write": true
      }
    },
    "rooms": {
      ".read": true,
      ".write": true,
      "$roomId": {
        "chat": {
          ".indexOn": ["ts"]
        }
      }
    },
    "pichan": {
      ".read": true,
      "$uid": {
        ".write": true
      }
    }
  }
}
